rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    // Note: Allowing read to stories even for unverified users for better UX, but writes require verification.
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidStory(data) {
      return data.keys().hasAll(['title', 'content', 'state', 'category', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 10000
        && data.state is string && data.state.size() <= 50
        && data.category is string && data.category.size() <= 50
        && data.createdAt is timestamp;
    }

    function isValidContribution(data) {
      // Required fields check
      return data.keys().hasAll(['title', 'content', 'state', 'author', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 5000
        && data.state is string && data.state.size() <= 50
        && data.author == request.auth.token.email
        && data.createdAt == request.time;
    }

    // 1. Stories: Main collection for published cultural stories
    match /stories/{storyId} {
      allow get: if isValidId(storyId);
      // Pillar 8: Secure List Queries (Enforce boundaries)
      // Stories are public, so we allow listing but without complex filters that bypass security.
      allow list: if true; 
      allow write: if false; // Only Admin or System (handled via Service Accounts which bypass rules)
    }

    // 2. Contributions: Collection for user-submitted cultural traditions
    match /contributions/{contributionId} {
      allow get: if isVerified() && isValidId(contributionId) && existing().author == request.auth.token.email;
      
      // Pillar 8: Secure List Queries
      // Logic evaluates resource.data against request.auth.uid or owner email.
      allow list: if isVerified() && resource.data.author == request.auth.token.email;
      
      allow create: if isVerified() && isValidId(contributionId) && isValidContribution(incoming());
      
      allow update: if isVerified() && isValidId(contributionId) && isValidContribution(incoming())
        && incoming().author == existing().author
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Edit content
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'state', 'category', 'image'])
        );
      
      allow delete: if isVerified() && isValidId(contributionId) && existing().author == request.auth.token.email;
    }
  }
}
