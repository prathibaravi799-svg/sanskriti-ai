rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functionality
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Artist Profile Rules
    match /artists/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Product Rules
    match /products/{id=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Application Rules
    match /artisanApplications/{id=**} {
      allow read, write: if isSignedIn();
    }

    // Generic fallback for other collections mentioned in blueprint
    match /stories/{id=**} { allow read: if true; allow write: if isSignedIn(); }
    match /carts/{id=**} { allow read, write: if isSignedIn(); }
    match /bookings/{id=**} { allow read, write: if isSignedIn(); }
    match /liveSessions/{id=**} { allow read, write: if isSignedIn(); }
    match /videos/{id=**} { allow read, write: if isSignedIn(); }
    match /reviews/{id=**} { allow read: if true; allow write: if isSignedIn(); }
    match /achievements/{id=**} { allow read, write: if isSignedIn(); }
    match /chats/{id=**} { allow read, write: if isSignedIn(); }
    match /folklore/{id=**} { allow read: if true; allow write: if isSignedIn(); }
    match /chapters/{id=**} { allow read: if true; allow write: if isSignedIn(); }
    match /streams/{id=**} { allow read: if true; allow write: if isSignedIn(); }
    match /comments/{id=**} { allow read: if true; allow write: if isSignedIn(); }

    // Test connection
    match /test/connection {
      allow read: if true;
    }
  }
}
